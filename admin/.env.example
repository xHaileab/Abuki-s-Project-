# Backend URL the admin app talks to. In dev, leave blank to use the Vite proxy.
# In production (Railway), set to your deployed backend URL.
VITE_BACKEND_URL=

# Gebeta Maps API key (from https://gebeta.app/dashboard).
# When set, the admin map renders with Gebeta tiles. When unset, falls back
# to OpenStreetMap.
VITE_GEBETA_API_KEY=

# Optional override of the Gebeta style URL. Default:
# https://tiles.gebeta.app/styles/standard/style.json
VITE_GEBETA_STYLE_URL=
