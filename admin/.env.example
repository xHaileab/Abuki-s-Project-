# Backend URL the admin app talks to. In dev, leave blank to use the Vite proxy.
# In production (Railway), set to your deployed backend URL.
VITE_BACKEND_URL=

# Gebeta tile URL template. When set, the admin map uses Gebeta tiles. When
# blank, falls back to OpenStreetMap. Form: https://tiles.gebeta.app/{z}/{x}/{y}.png?apiKey=YOUR_KEY
VITE_GEBETA_TILE_URL=
