# Copy to .env and fill in. Never commit the real .env.

# Listen port for the API (Railway sets PORT itself; safe to leave blank there)
PORT=4000

# Optional comma-separated list of browser origins allowed to call the API.
# Leave blank for local/mobile development; set in production, e.g.:
# CORS_ORIGIN=https://your-admin.up.railway.app

# Shared admin bearer token. The admin web app sends this in Authorization headers.
# Generate something long and random, e.g.:  openssl rand -hex 32
ADMIN_TOKEN=

# Gebeta Maps API key (from https://gebeta.app/dashboard)
GEBETA_API_KEY=

# Optional: override SQLite database file location (Railway: point to a volume mount)
# DREAM_DB_PATH=/data/dream.db

# Firebase Functions only: use Firestore instead of local SQLite.
# DREAM_STORE=firestore
# FIRESTORE_DATABASE_ID=(default)
